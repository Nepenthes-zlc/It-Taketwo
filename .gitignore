__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Runtime outputs and large external repos.
runs/
logs/
test_results/
outputs/
verl/
mc_runtime/EnvMine/logs/
mc_runtime/EnvMine/test_results/
mc_runtime/EnvMine/envs/qwen-batch-*/
